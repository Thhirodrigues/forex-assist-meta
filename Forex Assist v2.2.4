@charset "utf-8";

:root { --bg: #0B1220; --card: #111827; --text: #E5E7EB; --muted: #9CA3AF; --green: #10B981; --red: #EF4444; --blue: #3B82F6; }

* { box-sizing: border-box; font-family: system-ui, -apple-system, "Segoe UI", Roboto, Arial; }

body { margin: 0px; background: var(--bg); color: var(--text); padding: 16px; }

h1 { margin: 0px 0px 6px; font-size: 22px; }

.status { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }

.dot { width: 10px; height: 10px; border-radius: 50%; background: var(--red); }

.dot.on { background: var(--green); box-shadow: 0 0 8px var(--green); }

button { width: 100%; padding: 15px; border: 0px; border-radius: 12px; background: var(--blue); color: rgb(255, 255, 255); font-weight: 700; font-size: 16px; margin: 8px 0px; cursor: pointer; }

button:active { transform: scale(0.98); }

.card { background: var(--card); padding: 16px; border-radius: 16px; margin: 12px 0px; }

.pills { display: flex; gap: 8px; flex-wrap: wrap; }

.pill { padding: 8px 12px; border-radius: 20px; background: rgb(31, 41, 55); color: var(--muted); cursor: pointer; font-size: 14px; }

.pill.active { background: var(--blue); color: rgb(255, 255, 255); }

.price { font-size: 34px; font-weight: 800; margin: 8px 0px; }

.grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

label { font-size: 12px; color: var(--muted); }

input { width: 100%; padding: 12px; border-radius: 10px; border: 1px solid rgb(55, 65, 81); background: rgb(15, 23, 42); color: rgb(255, 255, 255); font-size: 16px; }

small { color: var(--muted); }

.val { font-weight: 700; }
