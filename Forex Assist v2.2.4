<title>Forex Assist v2.2.4</title>

</head>
<body>
<h1>Forex Assist v2.2.4</h1>
<div class="status"><div class="dot" id="dot"></div><span id="stat">sem conexão</span></div>
<button id="btn">ATUALIZAR</button>

<div class="card">
<div class="pills" id="pairs"><div class="pill active">AUD/USD</div><div class="pill">EUR/USD</div><div class="pill">GBP/USD</div><div class="pill">USD/JPY</div><div class="pill">USD/CAD</div></div>
<div style="margin-top:14px">
<div><label>Par</label><div id="pair" class="val">AUD/USD</div></div>
<div class="price" id="live">--</div>
<small>Fonte: <span id="src">--</span> • <span id="tm">--</span></small>
</div>
<div class="grid" style="margin-top:14px">
<div><label>ENTRADA XM (+2p)</label><div id="ent" class="val">--</div></div>
<div><label>Spread</label><div class="val">2 pips</div></div>
<div><label>TP +7.5</label><div id="tp" class="val" style="color:var(--green)">--</div></div>
<div><label>SL -12.5</label><div id="sl" class="val" style="color:var(--red)">--</div></div>
</div>
</div>

<div class="card">
<h3 style="margin:0 0 8px">Calibrar com XM</h3>
<input id="xm" type="number" step="0.00001" placeholder="Preço que vê na XM">
<button id="cal" style="background:#059669">Calibrar agora</button>
<small>Offset: <span id="off">0.0</span> pips</small>
</div>



</body></html>
